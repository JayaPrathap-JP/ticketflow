{
  "name": "ticketflow-backend",
  "version": "2.0.0",
  "description": "TicketFlow ticket booking REST API",
  "main": "server.js",
  "scripts": {
    "start":           "node server.js",
    "dev":             "nodemon server.js",
    "test":            "jest --runInBand --forceExit",
    "test:unit":       "jest tests/unit --coverage --forceExit",
    "test:integration":"jest tests/integration --forceExit",
    "test:ci":         "jest --runInBand --forceExit --coverage --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "express":      "^4.18.2",
    "express-validator": "^7.0.1",
    "uuid":         "^9.0.0",
    "morgan":       "^1.10.0",
    "cors":         "^2.8.5"
  },
  "devDependencies": {
    "jest":          "^29.0.0",
    "supertest":     "^6.3.3",
    "jest-junit":    "^16.0.0",
    "nodemon":       "^3.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["**/*.js","!tests/**","!node_modules/**"],
    "coverageThreshold": {
      "global": { "lines": 5, "functions": 0, "branches": 0 }
    }
  }
}